---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(100%, 860px);
				margin: 0 auto;
				padding: 2.5rem 1rem 0;
			}
			.article-shell {
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 20px;
				box-shadow: 0 20px 40px rgba(var(--gray), 0.08);
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 0;
			}
			.prose {
				max-width: 760px;
				margin: 0 auto;
				padding: 2rem 1.25rem 2.5rem;
			}
			.title {
				margin-bottom: 2rem;
			}
			.title h1 {
				margin: 0.35rem 0 0.75rem;
				font-size: clamp(2rem, 5vw, 3.4rem);
				line-height: 1.05;
			}
			.eyebrow {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.category {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(var(--gray-light), 0.9);
				color: rgb(var(--gray-dark));
				font-weight: 700;
			}
			.description {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				margin-bottom: 1.25rem;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 1rem;
			}
			.tags span {
				font-size: 0.9rem;
				padding: 0.3rem 0.55rem;
				border-radius: 999px;
				background: rgba(var(--gray-light), 0.7);
				color: rgb(var(--gray));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article-shell">
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt="" loading="eager" />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="eyebrow">
							<span class="category">{category}</span>
							<span><FormattedDate date={pubDate} /></span>
							{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
						</div>
						<h1>{title}</h1>
						<p class="description">{description}</p>
						{tags?.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => <span>#{tag}</span>)}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
