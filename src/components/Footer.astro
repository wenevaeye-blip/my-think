---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p><strong>{SITE_TITLE}</strong></p>
		<p>&copy; {today.getFullYear()} {SITE_AUTHOR}. Small ideas, gently explained.</p>
	</div>
</footer>
<style>
	footer {
		padding: 2.5rem 1rem 4rem;
		border-top: 1px solid rgba(var(--gray-light), 1);
		margin-top: 3rem;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	.footer-inner p {
		margin: 0.35rem 0;
	}
</style>
