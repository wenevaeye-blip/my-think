---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<header>
	<nav>
		<h2><a href={base}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={link('/blog/')}>Blog</HeaderLink>
			<HeaderLink href={link('/about/')}>About</HeaderLink>
			<HeaderLink href={link('/privacy/')}>Privacy</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 1rem;
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray-light), 1);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		flex-wrap: wrap;
	}
	nav a {
		padding: 1rem 0.5rem;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 0.35rem 0 0.5rem;
		}
		.internal-links {
			gap: 0.1rem 0.5rem;
		}
		nav a {
			padding: 0.35rem 0.15rem;
		}
	}
</style>
