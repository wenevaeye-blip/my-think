---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft && post.data.category.toLowerCase() === 'neva diary')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const rawBase = import.meta.env.BASE_URL;
const normalizedBase = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path = '') => new URL(path.replace(/^\//, ''), `https://example.com${normalizedBase}`).pathname;
const postUrl = (id: string) => withBase(`/blog/${id}/`);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Neva's Diary | ${SITE_TITLE}`} description="Neva's Diary" />
		<style>
			.list {
				display: grid;
				gap: 1.25rem;
			}
			.item {
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 18px;
				padding: 1.25rem;
				box-shadow: 0 12px 28px rgba(var(--gray), 0.06);
				display: flex;
				gap: 1.25rem;
				align-items: flex-start;
			}
			.item-hero {
				width: 90px;
				height: 90px;
				border-radius: 12px;
				object-fit: cover;
				flex-shrink: 0;
			}
			.item-body {
				flex: 1;
				min-width: 0;
			}
			.item h2 {
				font-size: 1.35rem;
				margin-bottom: 0.4rem;
			}
			.meta {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin-bottom: 0.6rem;
			}
			.empty {
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			@media (max-width: 480px) {
				.item {
					flex-direction: column;
				}
				.item-hero {
					width: 100%;
					height: 160px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="list">
				{posts.length === 0 && <p class="empty">No entries yet.</p>}
				{posts.map((post) => (
					<article class="item">
						{post.data.heroImage && (
							<img class="item-hero" src={post.data.heroImage} alt="" loading="lazy" />
						)}
						<div class="item-body">
							<div class="meta">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h2><a href={postUrl(post.id)}>{post.data.title}</a></h2>
							<p>{post.data.description}</p>
						</div>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
