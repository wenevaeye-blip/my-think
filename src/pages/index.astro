---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const latest = posts.slice(1, 4);
const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: grid;
				gap: 1.5rem;
				padding-top: 1rem;
			}
			.hero-card,
			.card {
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 20px;
				padding: 1.5rem;
				box-shadow: 0 20px 40px rgba(var(--gray), 0.08);
			}
			.eyebrow {
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
			}
			.hero h1 {
				font-size: clamp(2.5rem, 6vw, 4.5rem);
				margin: 0.2rem 0 0.75rem;
				line-height: 1;
			}
			.lead {
				font-size: 1.15rem;
				max-width: 56rem;
				margin: 0;
			}
			.actions {
				display: flex;
				gap: 0.8rem;
				flex-wrap: wrap;
				margin-top: 1.25rem;
			}
			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.85rem 1.1rem;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
			}
			.button.primary {
				background: var(--accent);
				color: white;
			}
			.button.secondary {
				background: rgba(var(--gray-light), 0.8);
				color: rgb(var(--gray-dark));
			}
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin: 3rem 0 1rem;
			}
			.grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.card h3,
			.hero-card h2 {
				margin-bottom: 0.5rem;
			}
			.meta {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin-bottom: 0.75rem;
			}
			.card a,
			.hero-card a {
				text-decoration: none;
			}
			@media (max-width: 900px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<p class="eyebrow">English-first publishing setup</p>
					<h1>Build a practical content site around clean, useful writing.</h1>
					<p class="lead">
						This blog is designed for English articles, comparisons, explainers, and evergreen guides.
						It is intentionally simple now, so the publishing pipeline can grow without fighting the
						site structure.
					</p>
					<div class="actions">
						<a class="button primary" href={link('/blog')}>Browse articles</a>
						<a class="button secondary" href={link('/about')}>About this project</a>
					</div>
				</div>
				{featured && (
					<article class="hero-card">
						<p class="eyebrow">Latest article</p>
						<h2><a href={`${base}blog/${featured.id}/`}>{featured.data.title}</a></h2>
						<p class="meta"><FormattedDate date={featured.data.pubDate} /> · {featured.data.category}</p>
						<p>{featured.data.description}</p>
					</article>
				)}
			</section>

			<section>
				<div class="section-head">
					<h2>Recent posts</h2>
					<a href={link('/blog')}>View all</a>
				</div>
				<div class="grid">
					{latest.map((post) => (
						<article class="card">
							<p class="eyebrow">{post.data.category}</p>
							<h3><a href={`${base}blog/${post.id}/`}>{post.data.title}</a></h3>
							<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
							<p>{post.data.description}</p>
						</article>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
