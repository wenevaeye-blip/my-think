---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About My Think and the editorial focus behind the site." />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				My Think is a practical technology site for readers who want clear answers without marketing fluff.
				It focuses on simple explanations, comparisons, and real-world guidance for everyday digital tools.
			</p>
			<p>
				The editorial style is intentionally plain and useful. Articles are written to help readers make
				faster decisions, understand trade-offs, and avoid unnecessary complexity.
			</p>
			<p>
				Topics include cloud tools, home technology, buying decisions, digital workflow basics, and other
				areas where straightforward guidance is more useful than hype.
			</p>
		</main>
		<Footer />
	</body>
</html>
