---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About this English-first publishing project." />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				This site is an English-first publishing project built with Astro. The structure is intentionally
				simple so content generation, editing, and deployment can stay clean over time.
			</p>
			<p>
				The current focus is practical evergreen content: comparisons, buyer guides, explainers, and
				other useful articles that can scale into a stable publishing workflow.
			</p>
			<p>
				Over time, this site can be connected to a content engine that writes drafts, prepares images,
				and ships finished markdown directly into the blog.
			</p>
		</main>
		<Footer />
	</body>
</html>
