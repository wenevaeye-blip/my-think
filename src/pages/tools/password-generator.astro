---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const rawBase = import.meta.env.BASE_URL;
const normalizedBase = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path = '') => new URL(path.replace(/^\//, ''), `https://example.com${normalizedBase}`).pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Password Generator — Free Online Tool · ${SITE_TITLE}`} description="Generate strong, random passwords instantly. Choose length, character types, and copy with one click. Free, runs entirely in your browser — no passwords are ever sent to a server." />
		<script type="application/ld+json" is:inline>{`
		{
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Password Generator",
			"url": "https://wenevaeye-blip.github.io/my-think/tools/password-generator/",
			"description": "Generate strong, random passwords instantly. Choose length and character types. Runs entirely in your browser — no passwords are ever sent to a server.",
			"applicationCategory": "SecurityApplication",
			"operatingSystem": "Any",
			"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
		}
		`}</script>
		<style>
			.breadcrumb {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			.breadcrumb a { color: rgb(var(--gray)); text-decoration: none; }
			.breadcrumb a:hover { color: var(--accent); }
			.page-header { margin-bottom: 1.5rem; }
			.eyebrow {
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				margin: 0 0 0.4rem;
			}
			.page-header h1 {
				font-size: clamp(1.6rem, 4vw, 2.2rem);
				margin: 0 0 0.4rem;
				line-height: 1.1;
			}
			.lead { font-size: 0.95rem; color: rgb(var(--gray)); margin: 0; }
			.privacy-notice {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				margin-top: 0.65rem;
				padding: 0.4rem 0.85rem;
				background: rgba(35, 55, 255, 0.06);
				border: 1px solid rgba(35, 55, 255, 0.18);
				border-radius: 999px;
				font-size: 0.82rem;
				color: var(--accent-dark);
				font-weight: 700;
			}
			.tool-card {
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 20px;
				padding: 1.5rem;
				box-shadow: 0 20px 40px rgba(var(--gray), 0.08);
				margin-top: 1.5rem;
			}
			.output-row {
				display: flex;
				gap: 0.5rem;
				align-items: stretch;
				margin-bottom: 1.25rem;
			}
			.password-display {
				flex: 1;
				min-width: 0;
				padding: 0.85rem 1rem;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 12px;
				font-family: "Courier New", Courier, monospace;
				font-size: 1rem;
				font-weight: 700;
				color: rgb(var(--black));
				background: rgba(var(--gray-light), 0.18);
				box-sizing: border-box;
				letter-spacing: 0.06em;
				word-break: break-all;
				cursor: default;
				user-select: all;
			}
			.btn {
				padding: 0.55rem 1.1rem;
				border-radius: 999px;
				border: none;
				font-family: "Atkinson", sans-serif;
				font-size: 0.9rem;
				font-weight: 700;
				cursor: pointer;
				transition: opacity 0.12s;
				white-space: nowrap;
			}
			.btn:hover { opacity: 0.82; }
			.btn.primary { background: var(--accent); color: white; }
			.btn.secondary { background: rgba(var(--gray-light), 0.9); color: rgb(var(--gray-dark)); }
			.strength-bar-wrap {
				margin-bottom: 1.25rem;
			}
			.strength-label-row {
				display: flex;
				justify-content: space-between;
				font-size: 0.82rem;
				color: rgb(var(--gray));
				margin-bottom: 0.35rem;
			}
			.strength-label-row strong { color: rgb(var(--black)); }
			.strength-track {
				height: 6px;
				background: rgba(var(--gray-light), 0.6);
				border-radius: 999px;
				overflow: hidden;
			}
			.strength-fill {
				height: 100%;
				border-radius: 999px;
				transition: width 0.25s ease, background 0.25s ease;
				width: 0%;
				background: #c0392b;
			}
			.options-grid {
				display: grid;
				gap: 1rem;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				margin-bottom: 1.25rem;
			}
			.option-row {
				display: flex;
				align-items: center;
				gap: 0.6rem;
			}
			.option-row input[type="checkbox"] {
				width: 1.1rem;
				height: 1.1rem;
				accent-color: var(--accent);
				cursor: pointer;
				flex-shrink: 0;
			}
			.option-row label {
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
				cursor: pointer;
				user-select: none;
			}
			.length-row {
				margin-bottom: 1.25rem;
			}
			.length-label-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
			}
			.field-label {
				display: block;
				font-size: 0.82rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
			}
			.length-value {
				font-family: "Courier New", Courier, monospace;
				font-size: 1rem;
				font-weight: 700;
				color: var(--accent);
			}
			.length-slider {
				width: 100%;
				accent-color: var(--accent);
				cursor: pointer;
			}
			.actions-row {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}
			.status-msg {
				font-size: 0.85rem;
				margin-top: 0.75rem;
				min-height: 1.2em;
				color: rgb(var(--gray));
			}
			.status-msg.error { color: #c0392b; }
			.status-msg.success { color: #27ae60; }
			@media (max-width: 480px) {
				.options-grid { grid-template-columns: 1fr; }
				.output-row { flex-wrap: wrap; }
			}
			.about-section {
				margin-top: 2rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(var(--gray-light), 1);
			}
			.about-section h2 { font-size: 1.1rem; margin-bottom: 0.6rem; }
			.about-section p, .about-section li {
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
				line-height: 1.65;
				margin-bottom: 0.5rem;
			}
			.about-section ul { padding-left: 1.2rem; margin: 0.4rem 0 0.8rem; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href={withBase('/tools/')}>Tools</a> &rsaquo; Password Generator
			</nav>

			<header class="page-header">
				<p class="eyebrow">Utility</p>
				<h1>Password Generator</h1>
				<p class="lead">Generate strong, random passwords. Choose your length and character set.</p>
				<p class="privacy-notice" aria-label="Privacy assurance">
					🔒 Generated entirely in your browser — no password ever leaves your device.
				</p>
			</header>

			<section class="tool-card" aria-label="Password generator tool">
				<div class="output-row">
					<div class="password-display" id="password-display" aria-label="Generated password" aria-live="polite">—</div>
					<button class="btn secondary" id="btn-copy" aria-label="Copy password">Copy</button>
				</div>

				<div class="strength-bar-wrap" aria-label="Password strength">
					<div class="strength-label-row">
						<span>Strength</span>
						<strong id="strength-label">—</strong>
					</div>
					<div class="strength-track" role="progressbar" aria-labelledby="strength-label">
						<div class="strength-fill" id="strength-fill"></div>
					</div>
				</div>

				<div class="length-row">
					<div class="length-label-row">
						<label class="field-label" for="length-slider">Length</label>
						<span class="length-value" id="length-display">16</span>
					</div>
					<input class="length-slider" type="range" id="length-slider" min="8" max="64" value="16" />
				</div>

				<div class="options-grid" role="group" aria-label="Character types">
					<div class="option-row">
						<input type="checkbox" id="opt-upper" checked />
						<label for="opt-upper">Uppercase (A–Z)</label>
					</div>
					<div class="option-row">
						<input type="checkbox" id="opt-lower" checked />
						<label for="opt-lower">Lowercase (a–z)</label>
					</div>
					<div class="option-row">
						<input type="checkbox" id="opt-digits" checked />
						<label for="opt-digits">Digits (0–9)</label>
					</div>
					<div class="option-row">
						<input type="checkbox" id="opt-symbols" />
						<label for="opt-symbols">Symbols (!@#$…)</label>
					</div>
				</div>

				<div class="actions-row">
					<button class="btn primary" id="btn-generate">Generate</button>
					<button class="btn secondary" id="btn-regenerate">Regenerate</button>
				</div>
				<p class="status-msg" id="status-pw" aria-live="polite"></p>
			</section>

			<aside class="about-section">
				<h2>What makes a strong password?</h2>
				<p>
					A strong password combines <strong>length</strong> and <strong>character variety</strong>.
					Longer passwords are exponentially harder to brute-force — 16+ characters is a solid baseline.
					Mixing uppercase, lowercase, digits, and symbols expands the character space, making exhaustive attacks impractical.
				</p>
				<h2>Tips for using generated passwords</h2>
				<ul>
					<li>Use a password manager (Bitwarden, 1Password, etc.) to store generated passwords — you don't need to memorise them.</li>
					<li>Use a unique password for every account. Reusing passwords means a single breach exposes everything.</li>
					<li>Enable two-factor authentication (2FA) wherever possible — it adds a layer no password alone can provide.</li>
					<li>Never type or paste passwords into sites over HTTP (no padlock in the browser).</li>
				</ul>
				<h2>How the generator works</h2>
				<p>
					Passwords are built using the browser's built-in
					<code>crypto.getRandomValues()</code> API, which provides
					cryptographically secure random numbers. No Math.random() — no predictable patterns.
					Nothing is sent over the network; the entire process happens locally on your device.
				</p>
			</aside>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
				const LOWER = 'abcdefghijklmnopqrstuvwxyz';
				const DIGITS = '0123456789';
				const SYMBOLS = '!@#$%^&*()-_=+[]{}|;:,.<>?';

				const displayEl = document.getElementById('password-display');
				const copyBtn = document.getElementById('btn-copy');
				const lengthSlider = document.getElementById('length-slider');
				const lengthDisplay = document.getElementById('length-display');
				const statusEl = document.getElementById('status-pw');
				const strengthFill = document.getElementById('strength-fill');
				const strengthLabel = document.getElementById('strength-label');

				function setStatus(msg, type) {
					statusEl.textContent = msg;
					statusEl.className = 'status-msg' + (type ? ' ' + type : '');
					if (type === 'success') setTimeout(() => { statusEl.textContent = ''; statusEl.className = 'status-msg'; }, 2000);
				}

				function getCharset() {
					let charset = '';
					if (document.getElementById('opt-upper').checked) charset += UPPER;
					if (document.getElementById('opt-lower').checked) charset += LOWER;
					if (document.getElementById('opt-digits').checked) charset += DIGITS;
					if (document.getElementById('opt-symbols').checked) charset += SYMBOLS;
					return charset;
				}

				function getRequiredSets() {
					const sets = [];
					if (document.getElementById('opt-upper').checked) sets.push(UPPER);
					if (document.getElementById('opt-lower').checked) sets.push(LOWER);
					if (document.getElementById('opt-digits').checked) sets.push(DIGITS);
					if (document.getElementById('opt-symbols').checked) sets.push(SYMBOLS);
					return sets;
				}

				function secureRandInt(max) {
					const arr = new Uint32Array(1);
					crypto.getRandomValues(arr);
					return arr[0] % max;
				}

				function generate() {
					const charset = getCharset();
					if (!charset) { setStatus('Select at least one character type.', 'error'); return null; }
					const length = parseInt(lengthSlider.value, 10);
					const required = getRequiredSets();

					// Build password ensuring at least one char from each required set
					const result = [];
					// Fill required slots first
					for (const set of required) {
						result.push(set[secureRandInt(set.length)]);
					}
					// Fill remaining slots
					while (result.length < length) {
						result.push(charset[secureRandInt(charset.length)]);
					}
					// Shuffle using Fisher-Yates with crypto random
					for (let i = result.length - 1; i > 0; i--) {
						const j = secureRandInt(i + 1);
						[result[i], result[j]] = [result[j], result[i]];
					}
					return result.join('');
				}

				function calcStrength(password) {
					if (!password || password === '—') return { score: 0, label: '—', color: '#ccc', pct: 0 };
					const len = password.length;
					let score = 0;
					if (len >= 8) score++;
					if (len >= 12) score++;
					if (len >= 16) score++;
					if (len >= 20) score++;
					if (/[A-Z]/.test(password)) score++;
					if (/[a-z]/.test(password)) score++;
					if (/[0-9]/.test(password)) score++;
					if (/[^A-Za-z0-9]/.test(password)) score++;

					if (score <= 3) return { label: 'Weak', color: '#c0392b', pct: 25 };
					if (score <= 5) return { label: 'Fair', color: '#e67e22', pct: 50 };
					if (score <= 6) return { label: 'Good', color: '#f1c40f', pct: 72 };
					return { label: 'Strong', color: '#27ae60', pct: 100 };
				}

				function updateStrength(password) {
					const { label, color, pct } = calcStrength(password);
					strengthLabel.textContent = label;
					strengthFill.style.width = pct + '%';
					strengthFill.style.background = color;
				}

				function run() {
					const pw = generate();
					if (!pw) return;
					displayEl.textContent = pw;
					updateStrength(pw);
					statusEl.textContent = '';
					statusEl.className = 'status-msg';
				}

				// Init
				run();

				lengthSlider.addEventListener('input', () => {
					lengthDisplay.textContent = lengthSlider.value;
					run();
				});

				['opt-upper', 'opt-lower', 'opt-digits', 'opt-symbols'].forEach(id => {
					document.getElementById(id).addEventListener('change', run);
				});

				document.getElementById('btn-generate').addEventListener('click', run);
				document.getElementById('btn-regenerate').addEventListener('click', run);

				copyBtn.addEventListener('click', async () => {
					const pw = displayEl.textContent;
					if (!pw || pw === '—') { setStatus('Nothing to copy.', ''); return; }
					try {
						await navigator.clipboard.writeText(pw);
						setStatus('Copied!', 'success');
					} catch {
						setStatus('Copy failed — select and copy manually.', 'error');
					}
				});
			})();
		</script>
	</body>
</html>
