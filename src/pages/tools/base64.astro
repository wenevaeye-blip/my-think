---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const rawBase = import.meta.env.BASE_URL;
const normalizedBase = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path = '') => new URL(path.replace(/^\//, ''), `https://example.com${normalizedBase}`).pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Base64 Encoder / Decoder — Free Online Tool · ${SITE_TITLE}`} description="Free online Base64 encoder and decoder. Convert text or data to Base64 format and back instantly in your browser. No sign-up, no data sent to any server." />
		<script type="application/ld+json" is:inline>{`
		{
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Base64 Encoder / Decoder",
			"url": "https://wenevaeye-blip.github.io/my-think/tools/base64/",
			"description": "Free online Base64 encoder and decoder. Convert plain text or binary data to Base64 and back. Runs entirely in your browser — no data is sent to any server.",
			"applicationCategory": "DeveloperApplication",
			"operatingSystem": "Any",
			"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
		}
		`}</script>
		<style>
			.breadcrumb {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover { color: var(--accent); }
			.page-header { margin-bottom: 1.5rem; }
			.eyebrow {
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				margin: 0 0 0.4rem;
			}
			.page-header h1 {
				font-size: clamp(1.6rem, 4vw, 2.2rem);
				margin: 0 0 0.4rem;
				line-height: 1.1;
			}
			.lead {
				font-size: 0.95rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.privacy-notice {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				margin-top: 0.65rem;
				padding: 0.4rem 0.85rem;
				background: rgba(35, 55, 255, 0.06);
				border: 1px solid rgba(35, 55, 255, 0.18);
				border-radius: 999px;
				font-size: 0.82rem;
				color: var(--accent-dark);
				font-weight: 700;
			}
			.tool-card {
				background: white;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 20px;
				padding: 1.5rem;
				box-shadow: 0 20px 40px rgba(var(--gray), 0.08);
				margin-top: 1.5rem;
			}
			.mode-tabs {
				display: flex;
				gap: 0.4rem;
				margin-bottom: 1.25rem;
			}
			.tab-btn {
				padding: 0.45rem 1rem;
				border-radius: 999px;
				border: 1px solid rgba(var(--gray-light), 1);
				background: transparent;
				font-family: "Atkinson", sans-serif;
				font-size: 0.9rem;
				cursor: pointer;
				color: rgb(var(--gray-dark));
				transition: background 0.12s, color 0.12s;
			}
			.tab-btn.active {
				background: var(--accent);
				color: white;
				border-color: var(--accent);
			}
			.field-label {
				display: block;
				font-size: 0.82rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
				margin-bottom: 0.4rem;
			}
			.io-area {
				width: 100%;
				min-height: 130px;
				padding: 0.85rem 1rem;
				border: 1px solid rgba(var(--gray-light), 1);
				border-radius: 12px;
				font-family: "Courier New", Courier, monospace;
				font-size: 0.88rem;
				line-height: 1.55;
				resize: vertical;
				box-sizing: border-box;
				color: rgb(var(--gray-dark));
				background: rgba(var(--gray-light), 0.18);
				transition: border-color 0.12s;
			}
			.io-area:focus { outline: none; border-color: var(--accent); }
			.io-area[readonly] {
				background: rgba(var(--gray-light), 0.35);
				cursor: default;
			}
			.divider {
				display: flex;
				align-items: center;
				justify-content: center;
				margin: 0.75rem 0;
				font-size: 1.2rem;
				color: rgb(var(--gray));
				user-select: none;
			}
			.actions-row {
				display: flex;
				gap: 0.5rem;
				margin-top: 0.75rem;
				flex-wrap: wrap;
			}
			.btn {
				padding: 0.55rem 1.1rem;
				border-radius: 999px;
				border: none;
				font-family: "Atkinson", sans-serif;
				font-size: 0.9rem;
				font-weight: 700;
				cursor: pointer;
				transition: opacity 0.12s;
			}
			.btn:hover { opacity: 0.82; }
			.btn.primary { background: var(--accent); color: white; }
			.btn.secondary {
				background: rgba(var(--gray-light), 0.9);
				color: rgb(var(--gray-dark));
			}
			.status-msg {
				font-size: 0.85rem;
				margin-top: 0.5rem;
				min-height: 1.2em;
				color: rgb(var(--gray));
			}
			.status-msg.error { color: #c0392b; }
			.status-msg.success { color: #27ae60; }
			.about-section {
				margin-top: 2rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(var(--gray-light), 1);
			}
			.about-section h2 { font-size: 1.1rem; margin-bottom: 0.6rem; }
			.about-section p, .about-section li {
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
				line-height: 1.65;
				margin-bottom: 0.5rem;
			}
			.about-section ul {
				padding-left: 1.2rem;
				margin: 0.4rem 0 0.8rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href={withBase('/tools/')}>Tools</a> &rsaquo; Base64 Encoder / Decoder
			</nav>

			<header class="page-header">
				<p class="eyebrow">Utility</p>
				<h1>Base64 Encoder / Decoder</h1>
				<p class="lead">Encode text to Base64 or decode a Base64 string back to plain text.</p>
				<p class="privacy-notice" aria-label="Privacy assurance">
					🔒 Your data never leaves your device — no servers, no tracking, no worries.
				</p>
			</header>

			<section class="tool-card" aria-label="Base64 codec tool">
				<div class="mode-tabs" role="tablist">
					<button class="tab-btn active" id="tab-encode" role="tab" aria-selected="true" aria-controls="panel-encode">Encode</button>
					<button class="tab-btn" id="tab-decode" role="tab" aria-selected="false" aria-controls="panel-decode">Decode</button>
				</div>

				<div id="panel-encode" role="tabpanel" aria-labelledby="tab-encode">
					<label class="field-label" for="encode-input">Plain text</label>
					<textarea class="io-area" id="encode-input" placeholder="Paste text to encode…" spellcheck="false"></textarea>
					<div class="divider" aria-hidden="true">↓</div>
					<label class="field-label" for="encode-output">Base64 output</label>
					<textarea class="io-area" id="encode-output" readonly placeholder="Result will appear here…" spellcheck="false"></textarea>
					<div class="actions-row">
						<button class="btn primary" id="btn-encode">Encode</button>
						<button class="btn secondary" id="btn-copy-encode">Copy result</button>
						<button class="btn secondary" id="btn-clear-encode">Clear</button>
					</div>
					<p class="status-msg" id="status-encode" aria-live="polite"></p>
				</div>

				<div id="panel-decode" role="tabpanel" aria-labelledby="tab-decode" hidden>
					<label class="field-label" for="decode-input">Base64 string</label>
					<textarea class="io-area" id="decode-input" placeholder="Paste a Base64 string to decode…" spellcheck="false"></textarea>
					<div class="divider" aria-hidden="true">↓</div>
					<label class="field-label" for="decode-output">Decoded output</label>
					<textarea class="io-area" id="decode-output" readonly placeholder="Result will appear here…" spellcheck="false"></textarea>
					<div class="actions-row">
						<button class="btn primary" id="btn-decode">Decode</button>
						<button class="btn secondary" id="btn-copy-decode">Copy result</button>
						<button class="btn secondary" id="btn-clear-decode">Clear</button>
					</div>
					<p class="status-msg" id="status-decode" aria-live="polite"></p>
				</div>
			</section>

			<aside class="about-section">
				<h2>What is Base64?</h2>
				<p>
					Base64 is an encoding scheme that converts binary data into a string of ASCII characters.
					It uses 64 printable characters (A–Z, a–z, 0–9, +, /) so that binary content can be
					safely transmitted over text-based channels like email, JSON payloads, or HTML attributes.
				</p>
				<h2>Common uses</h2>
				<ul>
					<li>Embedding images or fonts directly in CSS or HTML as <code>data:</code> URIs</li>
					<li>Encoding credentials in HTTP Basic Authentication headers</li>
					<li>Passing binary data in JSON API requests or responses</li>
					<li>Reading JWT tokens — the header and payload sections are Base64-encoded</li>
				</ul>
				<h2>How to use</h2>
				<p>
					Paste any plain text into the <strong>Encode</strong> tab and press Encode.
					To reverse the process, switch to the <strong>Decode</strong> tab and paste a Base64 string.
					Everything runs locally in your browser — your data is never sent to a server.
				</p>
			</aside>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const tabEncode = document.getElementById('tab-encode');
				const tabDecode = document.getElementById('tab-decode');
				const panelEncode = document.getElementById('panel-encode');
				const panelDecode = document.getElementById('panel-decode');

				function switchTab(active, inactive, show, hide) {
					active.classList.add('active');
					active.setAttribute('aria-selected', 'true');
					inactive.classList.remove('active');
					inactive.setAttribute('aria-selected', 'false');
					show.hidden = false;
					hide.hidden = true;
				}
				tabEncode.addEventListener('click', () => switchTab(tabEncode, tabDecode, panelEncode, panelDecode));
				tabDecode.addEventListener('click', () => switchTab(tabDecode, tabEncode, panelDecode, panelEncode));

				function setStatus(id, msg, type) {
					const el = document.getElementById(id);
					el.textContent = msg;
					el.className = 'status-msg' + (type ? ' ' + type : '');
					if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'status-msg'; }, 2000);
				}

				async function copyText(text, statusId) {
					try {
						await navigator.clipboard.writeText(text);
						setStatus(statusId, 'Copied!', 'success');
					} catch {
						setStatus(statusId, 'Copy failed — select and copy manually.', 'error');
					}
				}

				document.getElementById('btn-encode').addEventListener('click', () => {
					const input = document.getElementById('encode-input').value;
					if (!input) { setStatus('status-encode', 'Nothing to encode.', ''); return; }
					try {
						document.getElementById('encode-output').value = btoa(unescape(encodeURIComponent(input)));
						setStatus('status-encode', '', '');
					} catch (e) {
						setStatus('status-encode', 'Encoding failed: ' + e.message, 'error');
					}
				});

				document.getElementById('btn-copy-encode').addEventListener('click', () => {
					const val = document.getElementById('encode-output').value;
					if (!val) { setStatus('status-encode', 'Nothing to copy.', ''); return; }
					copyText(val, 'status-encode');
				});

				document.getElementById('btn-clear-encode').addEventListener('click', () => {
					document.getElementById('encode-input').value = '';
					document.getElementById('encode-output').value = '';
					setStatus('status-encode', '', '');
				});

				document.getElementById('btn-decode').addEventListener('click', () => {
					const input = document.getElementById('decode-input').value.trim();
					if (!input) { setStatus('status-decode', 'Nothing to decode.', ''); return; }
					try {
						document.getElementById('decode-output').value = decodeURIComponent(escape(atob(input)));
						setStatus('status-decode', '', '');
					} catch (e) {
						setStatus('status-decode', 'Invalid Base64: ' + e.message, 'error');
					}
				});

				document.getElementById('btn-copy-decode').addEventListener('click', () => {
					const val = document.getElementById('decode-output').value;
					if (!val) { setStatus('status-decode', 'Nothing to copy.', ''); return; }
					copyText(val, 'status-decode');
				});

				document.getElementById('btn-clear-decode').addEventListener('click', () => {
					document.getElementById('decode-input').value = '';
					document.getElementById('decode-output').value = '';
					setStatus('status-decode', '', '');
				});
			})();
		</script>
	</body>
</html>
